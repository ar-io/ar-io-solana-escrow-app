        "@solana/wallet-adapter-react-ui": "^0.9.0",
        "@solana/wallet-adapter-wallets": "^0.19.0",
        "bs58": "^6.0.0",
        "buffer": "^6.0.3",
        "ethers": "^6.13.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.0.0",
        "permaweb-deploy": "^2.1.0",
        "typescript": "^5.3.0",
