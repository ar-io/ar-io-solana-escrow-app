    },
    "description": "Web UI for the AR.IO ANT escrow program. Forked from ar-io-solana-registration-app — same wallet plumbing, repurposed for trustless multi-protocol ANT custody (deposit / claim / manage / lookup flows).",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "deploy": "yarn build && permaweb-deploy deploy --arns-name \"${VITE_ARNS_NAME:?set VITE_ARNS_NAME to the ArNS name to assign}\""
    },
    "dependencies": {
        "@ar.io/sdk": "4.0.0-solana.20",
