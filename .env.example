# ─── App config (baked into the bundle at build time) ──────────────────────

# Solana RPC endpoint. Defaults to mainnet-beta. The footer selector overrides
# this and persists to localStorage. For a devnet build:
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# The ario-ant-escrow program id. REQUIRED for escrow actions — the SDK ships no
# escrow program id for any public cluster, so point this at your deployment
# (localnet / surfpool / private validator). The footer "escrow program ID"
# input overrides this and persists to localStorage.
VITE_ESCROW_PROGRAM_ID=

# Off-chain attestor service URL. Required only for Arweave-recipient claims
# (Ethereum claims verify on-chain). Without it, Arweave claims fail at submit.
VITE_ATTESTOR_URL=http://localhost:3030

# Show deposit flows (ANT, tokens, vault). Off by default — the app is
# claim/manage/lookup-only unless explicitly enabled at build time.
# VITE_DEPOSITS_ENABLED=true

# Optional overrides (otherwise inferred from VITE_SOLANA_RPC_URL):
# VITE_ESCROW_NETWORK=solana-devnet      # solana-mainnet | solana-devnet
# VITE_ARIO_MINT=<spl mint address>      # ARIO mint for token/vault flows

# ─── Deploy (yarn deploy → permaweb-deploy) ────────────────────────────────

# ArNS name to assign the deployed manifest to (you must own it on AR.IO).
VITE_ARNS_NAME=my-escrow-app

# Arweave deploy wallet, base64-encoded JWK. Set at deploy time only — never
# commit it. Generate with:  export DEPLOY_KEY=$(base64 -i wallet.json)
# (Alternatively pass --wallet ./wallet.json or --private-key to permaweb-deploy.)
# DEPLOY_KEY=
